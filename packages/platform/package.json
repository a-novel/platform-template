{
  "name": "@a-novel/platform-template",
  "version": "0.0.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/a-novel/platform-template.git"
  },
  "license": "AGPL-3.0",
  "sideEffects": [
    "**/*.css"
  ],
  "type": "module",
  "exports": {
    "./ui": {
      "types": "./dist/ui/index.d.ts",
      "import": "./dist/ui/index.js",
      "svelte": "./dist/ui/index.js"
    },
    "./locales": {
      "types": "./dist/locales/index.d.ts",
      "import": "./dist/locales/index.js",
      "svelte": "./dist/locales/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && pnpm prepack",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "dev": "vite dev",
    "generate": "pnpm generate:translations",
    "generate:check": "pnpm generate:translations:check",
    "generate:translations": "pnpm generate:translations:sync && pnpm generate:translations:pull",
    "generate:translations:check": "pnpm tolgee compare check --api-key ${TOLGEE_PLATFORM_API_KEY} --api-url ${TOLGEE_URL}",
    "generate:translations:pull": "pnpm tolgee pull --api-key ${TOLGEE_PLATFORM_API_KEY} --api-url ${TOLGEE_URL}",
    "generate:translations:push": "pnpm tolgee push --api-key ${TOLGEE_PLATFORM_API_KEY} --api-url ${TOLGEE_URL}",
    "generate:translations:sync": "pnpm tolgee sync --yes --verbose --api-key ${TOLGEE_PLATFORM_API_KEY} --api-url ${TOLGEE_URL}",
    "preinstall": "npx only-allow pnpm",
    "prepack": "svelte-kit sync && svelte-package && publint",
    "prepare": "svelte-kit sync || echo ''",
    "preview": "vite preview",
    "test": "pnpm run test:unit",
    "test:unit": "vitest run",
    "translations:push": "pnpm tolgee push --api-key ${TOLGEE_PLATFORM_API_KEY} --api-url ${TOLGEE_URL}"
  },
  "devDependencies": {
    "@a-novel-kit/nodelib-browser": "catalog:",
    "@a-novel-kit/nodelib-config": "catalog:",
    "@a-novel/package-authentication": "catalog:",
    "@a-novel/service-authentication-rest": "catalog:",
    "@a-novel/uikit": "catalog:",
    "@eslint/compat": "catalog:",
    "@eslint/js": "catalog:",
    "@iconify/svelte": "^5.2.1",
    "@sveltejs/adapter-node": "catalog:",
    "@sveltejs/kit": "catalog:",
    "@sveltejs/package": "catalog:",
    "@sveltejs/vite-plugin-svelte": "catalog:",
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/svelte": "catalog:",
    "@testing-library/user-event": "catalog:",
    "@tolgee/cli": "catalog:",
    "@tolgee/core": "catalog:",
    "@tolgee/format-icu": "^7.0.0",
    "@tolgee/svelte": "^7.0.0",
    "@tolgee/web": "^7.0.0",
    "@types/jsdom": "catalog:",
    "@types/node": "^24.1.0",
    "@vitest/browser": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "eslint": "catalog:",
    "eslint-config-prettier": "catalog:",
    "eslint-plugin-svelte": "catalog:",
    "globals": "catalog:",
    "jsdom": "catalog:",
    "prettier": "catalog:",
    "prettier-plugin-svelte": "^3.4.0",
    "publint": "^0.3.16",
    "sharp": "catalog:",
    "svelte": "catalog:",
    "svelte-check": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "^8.50.0",
    "vite": "catalog:",
    "vitest": "^4.1.0",
    "vitest-browser-svelte": "catalog:",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@a-novel-kit/nodelib-browser": "^1.3.28",
    "@a-novel/package-authentication": "^0.1.2",
    "@a-novel/uikit": "^0.13.0",
    "@iconify/svelte": "^5.2.1",
    "@sveltejs/kit": "^2.56.1",
    "@tolgee/core": "^7.0.0",
    "@tolgee/format-icu": "^7.0.0",
    "@tolgee/svelte": "^7.0.0",
    "@tolgee/web": "^7.0.0",
    "svelte": "^5.55.1",
    "zod": "^4.3.6"
  },
  "packageManager": "pnpm@10.33.0",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "tolgee": {
    "$schema": "https://docs.tolgee.io/cli-schema.json",
    "projectId": 1,
    "format": "JSON_ICU",
    "defaultNamespace": "template",
    "patterns": [
      "./src/**/*.ts",
      "./src/**/*.svelte"
    ],
    "push": {
      "filesTemplate": "./src/lib/locales/tr/{namespace}/{languageTag}.{extension}",
      "language": [
        "en",
        "fr"
      ],
      "forceMode": "OVERRIDE",
      "namespaces": [
        "template.common"
      ],
      "removeOtherKeys": true
    },
    "pull": {
      "path": "./src/lib/locales/tr/",
      "filesTemplate": "{namespace}/{languageTag}.{extension} ",
      "emptyDir": true,
      "delimiter": ""
    },
    "sync": {
      "removeUnused": true
    }
  }
}
