CREATE UNIQUE INDEX user_account_third_party_auth_id_third_party_auth_type_idx ON public.user_account USING btree (third_party_auth_id, third_party_auth_type) WHERE (deleted_at IS NULL);


--
-- Name: user_account_username_idx; Type: INDEX; Schema: public; Owner: postgres
--

CREATE UNIQUE INDEX user_account_username_idx ON public.user_account USING btree (username) WHERE (deleted_at IS NULL);


--
-- Name: api_key hash_new_api_key; Type: TRIGGER; Schema: public; Owner: postgres
--

