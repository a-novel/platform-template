DROP FUNCTION IF EXISTS public.hash_new_api_key();
DROP FUNCTION IF EXISTS public.f_unaccent(text);
DROP FUNCTION IF EXISTS public.empty_json(j jsonb);
DROP EXTENSION IF EXISTS unaccent;
DROP EXTENSION IF EXISTS pg_trgm;
DROP SCHEMA IF EXISTS ee;
--
-- Name: ee; Type: SCHEMA; Schema: -; Owner: postgres
--

CREATE SCHEMA ee;


ALTER SCHEMA ee OWNER TO postgres;

--
-- Name: pg_trgm; Type: EXTENSION; Schema: -; Owner: -
--

CREATE EXTENSION IF NOT EXISTS pg_trgm WITH SCHEMA public;


--
-- Name: EXTENSION pg_trgm; Type: COMMENT; Schema: -; Owner: 
--

COMMENT ON EXTENSION pg_trgm IS 'text similarity measurement and index searching based on trigrams';


--
-- Name: unaccent; Type: EXTENSION; Schema: -; Owner: -
--

CREATE EXTENSION IF NOT EXISTS unaccent WITH SCHEMA public;


--
-- Name: EXTENSION unaccent; Type: COMMENT; Schema: -; Owner: 
--

COMMENT ON EXTENSION unaccent IS 'text search dictionary that removes accents';


--
-- Name: empty_json(jsonb); Type: FUNCTION; Schema: public; Owner: postgres
--

CREATE FUNCTION public.empty_json(j jsonb) RETURNS boolean
    LANGUAGE plpgsql IMMUTABLE
    AS $$
            BEGIN
            RETURN j = '{}'::jsonb;
            END;
            $$;


ALTER FUNCTION public.empty_json(j jsonb) OWNER TO postgres;

--
-- Name: f_unaccent(text); Type: FUNCTION; Schema: public; Owner: postgres
--

CREATE FUNCTION public.f_unaccent(text) RETURNS text
    LANGUAGE sql IMMUTABLE STRICT PARALLEL SAFE
    AS $_$
            SELECT public.unaccent('public.unaccent', $1)
                       $_$;


ALTER FUNCTION public.f_unaccent(text) OWNER TO postgres;

--
-- Name: hash_new_api_key(); Type: FUNCTION; Schema: public; Owner: postgres
--

CREATE FUNCTION public.hash_new_api_key() RETURNS trigger
    LANGUAGE plpgsql
    AS $$
BEGIN
    IF NEW.key is not null and NEW.key_hash is null THEN
        NEW.key_hash = encode(sha256(NEW.key::bytea), 'base64');
        NEW.key = null;
    END IF;
    RETURN NEW;
END
$$;


ALTER FUNCTION public.hash_new_api_key() OWNER TO postgres;

SET default_tablespace = '';

SET default_table_access_method = heap;

--
-- Name: ee_subscription; Type: TABLE; Schema: ee; Owner: postgres
--

CREATE TABLE ee.ee_subscription (
    id integer NOT NULL,
    created_at timestamp without time zone NOT NULL,
    updated_at timestamp without time zone NOT NULL,
    current_period_end timestamp without time zone,
    enabled_features character varying[],
    license_key character varying(255),
    last_valid_check timestamp without time zone,
    status character varying(255) DEFAULT 'ACTIVE'::character varying,
    name character varying(255) DEFAULT 'Plan'::character varying,
    non_commercial boolean DEFAULT false NOT NULL,
    included_keys bigint DEFAULT '-1'::integer NOT NULL,
    included_seats bigint DEFAULT '-1'::integer NOT NULL,
    is_pay_as_you_go boolean DEFAULT true NOT NULL,
    keys_limit bigint DEFAULT '-1'::integer NOT NULL,
    seats_limit bigint DEFAULT '-1'::integer NOT NULL
);


ALTER TABLE ee.ee_subscription OWNER TO postgres;

--
-- Name: usage_to_report; Type: TABLE; Schema: ee; Owner: postgres
--

CREATE TABLE ee.usage_to_report (
    id integer NOT NULL,
    created_at timestamp(6) without time zone NOT NULL,
    updated_at timestamp(6) without time zone NOT NULL,
    keys_to_report bigint NOT NULL,
    last_reported_keys bigint NOT NULL,
    last_reported_seats bigint NOT NULL,
    reported_at timestamp(6) without time zone,
